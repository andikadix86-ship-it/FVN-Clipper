  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  contentLibrary     ContentLibraryItem? @relation(fields: [contentLibraryId], references: [id])

  @@index([status])
  @@index([scheduledAt])
  @@index([platform])
  @@index([sourceType])
  @@index([contentLibraryId])
}
