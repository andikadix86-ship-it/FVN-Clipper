generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Category {
  id            String              @id @default(cuid())
  name          String
  slug          String              @unique
  description   String?
  isActive      Boolean             @default(true)
  sourceType    SourceType          @default(REAL_API)
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
  opportunities AiClipOpportunity[]
  campaigns     Campaign[]

  @@index([isActive])
  @@index([sourceType])
}

model Campaign {
  id                  String               @id @default(cuid())
  name                String
  slug                String               @unique
  description         String?
  platform            Platform             @default(ALL)
  status              ContentStatus        @default(DRAFT)
  categoryId          String?
  startDate           DateTime?
  endDate             DateTime?
  sourceType          SourceType           @default(REAL_API)
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  opportunities       AiClipOpportunity[]
  category            Category?            @relation(fields: [categoryId], references: [id])
  publishingSchedules PublishingSchedule[]

  @@index([categoryId])
  @@index([platform])
  @@index([status])
  @@index([sourceType])
}

model AiClipOpportunity {
  id                  String               @id @default(cuid())
  title               String
  slug                String               @unique
  description         String?
  niche               String
  keyword             String
  platform            Platform
  status              ContentStatus        @default(DRAFT)
  performanceLevel    PerformanceLevel
  opportunityScore    Int
  trendScore          Int
  competitionScore    Int
  viralPotentialScore Int
  aiRecommendation    String
  hookIdeas           Json
  contentAngles       Json
  thumbnailIdeas      Json?
  sourceUrl           String?
  sourceType          SourceType           @default(REAL_API)
  isSaved             Boolean              @default(false)
  savedAt             DateTime?
  categoryId          String?
  campaignId          String?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  campaign            Campaign?            @relation(fields: [campaignId], references: [id])
  category            Category?            @relation(fields: [categoryId], references: [id])
  publishingSchedules PublishingSchedule[]

  @@index([categoryId])
  @@index([campaignId])
  @@index([platform])
  @@index([status])
  @@index([performanceLevel])
  @@index([isSaved])
  @@index([opportunityScore])
  @@index([createdAt])
  @@index([sourceType])
}

model DashboardRecommendation {
  id                 String             @id @default(cuid())
  title              String
  summary            String
  priority           PriorityLevel
  recommendationType RecommendationType
  actionLabel        String?
  actionTarget       String?
  sourceType         SourceType         @default(REAL_API)
  isRead             Boolean            @default(false)
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  @@index([priority])
  @@index([recommendationType])
  @@index([isRead])
  @@index([sourceType])
  @@index([createdAt])
}

model PublishingSchedule {
  id            String                @id @default(cuid())
  title         String
  contentType   PublishingContentType
  platform      Platform
  status        ContentStatus         @default(DRAFT)
  scheduledAt   DateTime
  publishedAt   DateTime?
  campaignId    String?
  opportunityId String?
  sourceType    SourceType            @default(REAL_API)
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt
  campaign      Campaign?             @relation(fields: [campaignId], references: [id])
  opportunity   AiClipOpportunity?    @relation(fields: [opportunityId], references: [id])

  @@index([campaignId])
  @@index([opportunityId])
  @@index([platform])
  @@index([status])
  @@index([scheduledAt])
  @@index([sourceType])
}

model CompetitorProfile {
  id             String     @id @default(cuid())
  name           String
  platform       Platform
  handle         String?
  profileUrl     String?
  niche          String
  followers      Int?
  avgViews       Int?
  avgEngagement  Float?
  contentPattern Json?
  strengths      Json?
  weaknesses     Json?
  sourceType     SourceType @default(REAL_API)
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  @@index([platform])
  @@index([niche])
  @@index([sourceType])
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model AIAgent {
  id                  String                @id
  name                String
  role                AgentRole
  description         String
  status              AgentStatus           @default(ACTIVE)
  lastRunAt           DateTime?
  totalTasks          Int                   @default(0)
  successRate         Float                 @default(96)
  createdAt           DateTime              @default(now())
  updatedAt           DateTime
  AgentRecommendation AgentRecommendation[]
  AgentTask           AgentTask[]
  AutomationPlan      AutomationPlan[]
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model AIProvider {
  id                 String               @id
  name               AIProviderName       @unique
  apiKey             String?
